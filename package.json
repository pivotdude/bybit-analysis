    "test:coverage": "bun test --coverage",
    "verify": "bun run check && bun run test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  },
  "bin": {
    "bybit-analysis": "src/index.ts"
  }
}
